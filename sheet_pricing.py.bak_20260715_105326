def _cms_final_read_purchased_csv(job_dir):
    import csv

    csv_path = _cms_final_find_purchased_csv(job_dir)
    if csv_path is None:
        return []

    rows = []

    with csv_path.open("r", encoding="utf-8-sig", errors="replace", newline="") as f:
        reader = csv.DictReader(f)

        for raw in reader:
            component = " ".join(str(_cms_final_pc_get(raw, "Component", "Comp", "Name", "Item") or "").split())
            vendor = " ".join(str(_cms_final_pc_get(raw, "Vendor", "Manufacturer", "MFG") or "").split())
            part_number = " ".join(str(_cms_final_pc_get(raw, "PartNumber", "Part Number", "PartNo", "Part No", "Part #") or "").split())
            description = " ".join(str(_cms_final_pc_get(raw, "Description", "Desc") or "").split())

            qty = _cms_final_qty(_cms_final_pc_get(raw, "QTY", "Qty", "Quantity"), 1)
            unit_price = _cms_final_float(_cms_final_pc_get(raw, "UnitPrice", "Unit Price", "Price Each"), 0.0)
            extended = _cms_final_float(_cms_final_pc_get(raw, "Extended", "Ext", "Total", "Extended Price"), 0.0)

            if extended <= 0 and unit_price > 0:
                extended = unit_price * qty

            label = component or description or part_number
            if not label:
                continue

            if _cms_final_key(label) == "total":
                continue

            rows.append({
                "description": label,
                "name": label,
                "role": "purchased_component",
                "resolved_name": label,
                "role_group_name": "Purchased Components",
                "group": "Purchased Components",
                "category": "Purchased Components",
                "vendor": vendor,
                "part_number": part_number,
                "partNo": part_number,
                "part_no": part_number,
                "component": component,
                "component_description": description,
                "qty": qty,
                "quantity": qty,
                "unit_price": unit_price,
                "UnitPrice": unit_price,
                "price": extended,
                "total": extended,
                "extended": extended,
                "quoted": True,
                "quote": True,
                "pricing_note": "purchased",
                "source": "Purchased Components Quote.csv",
                "price_source": "job_csv:Purchased Components Quote.csv",
                "csv_path": str(csv_path),
            })

    return rows

