def _cms_final_norm(value):
    return " ".join(
        str(value or "")
        .replace("_", " ")
        .replace("-", " ")
        .replace(".", " ")
        .upper()
        .split()
    )


def _cms_final_key(value):
    return (
        str(value or "")
        .strip()
        .lower()
        .replace(" ", "")
        .replace("_", "")
        .replace("-", "")
        .replace(".", "")
        .replace("#", "")
    )


def _cms_final_float(value, default=0.0):
    try:
        s = str(value or "").strip().replace("$", "").replace(",", "")
        if not s:
            return default
        return float(s)
    except Exception:
        return default


def _cms_final_qty(value, default=1):
    try:
        s = str(value or "").strip()
        if not s:
            return default
        n = int(float(s))
        return n if n > 0 else default
    except Exception:
        return default


def _cms_final_bms_role(value):
    n = _cms_final_norm(value)

    if n in _CMS_FINAL_BMS_ALIASES:
        return _CMS_FINAL_BMS_ALIASES[n]

    for key, role in _CMS_FINAL_BMS_ALIASES.items():
        if key in n:
            return role

    return None


def _cms_final_kv_file(path):
    data = {}
    try:
        with open(path, "r", encoding="utf-8-sig", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                data[k.strip()] = v.strip()
    except Exception:
        pass
    return data


def _cms_final_job_dir_from_args(args, kwargs):
    from pathlib import Path

    for key in ("job_dir", "job_folder", "folder", "path", "job_path"):
        if key in kwargs:
            try:
                return Path(kwargs[key])
            except Exception:
                pass

    for arg in args:
        try:
            p = Path(arg)
            if str(p):
                return p
        except Exception:
            pass

    return None


def _cms_final_macro_done(job_dir):
    from pathlib import Path

    if job_dir is None:
        return False

    job_dir = Path(job_dir)

    log_path = job_dir / "CMS_Base_Export_Log.txt"
    try:
        if log_path.exists():
            txt = log_path.read_text(encoding="utf-8-sig", errors="replace").upper()
            if "DONE JOB" in txt or "DONE ACTIVE CAD QUOTE" in txt or "RUNACTIVEASSEMBLY COMPLETED" in txt:
                return True
    except Exception:
        pass

    workspace = Path(r"C:\CMS_Local_Workspace")

    status = _cms_final_kv_file(workspace / "cms_macro_status.txt")
    st = str(status.get("Status", "")).upper()
    folder = str(status.get("CurrentJobFolder", "")).strip().lower()

    if st in ("DONE", "COMPLETED"):
        if folder and folder == str(job_dir).strip().lower():
            return True

    done_path = workspace / "cms_macro_done.txt"
    try:
        if done_path.exists():
            csv_path = job_dir / "XT_Export_BOM_Match_Report.csv"
            if not csv_path.exists():
                return True
            if done_path.stat().st_mtime >= csv_path.stat().st_mtime:
                return True
    except Exception:
        pass

    return False


def _cms_final_find_quote_steel_workbooks(job_dir):
    from pathlib import Path

    if job_dir is None:
        return []

    job_dir = Path(job_dir)

    matches = []
    try:
        for p in job_dir.rglob("*"):
            if not p.is_file():
                continue

            name = p.name
            low = name.lower()

            if name.startswith("~$"):
                continue

            if not (low.endswith(".xlsx") or low.endswith(".xlsm")):
                continue

            if "quote" in low and "steel" in low and "grind" in low:
                matches.append(p)
    except Exception:
        pass

    matches.sort(key=lambda x: x.stat().st_mtime if x.exists() else 0, reverse=True)
    return matches


def _cms_final_make_steel_row(role, qty, thickness, width, length, source):
    return {
        "description": role,
        "name": role,
        "role": role,
        "resolved_name": role,
        "role_group_name": "Steel Plates / Mold Base",
        "group": "Steel Plates / Mold Base",
        "category": "Steel Plates / Mold Base",
        "qty": qty,
        "quantity": qty,
        "thickness": thickness,
        "width": width,
        "length": length,
        "Thickness": thickness,
        "Width": width,
        "Length": length,
        "hours": None,
        "price": 0.0,
        "total": 0.0,
        "quoted": True,
        "quote": True,
        "pricing_note": "sheet",
        "source": source,
        "price_source": source,
    }


def _cms_final_read_bms_from_quote_workbook(job_dir):
    try:
        import openpyxl
    except Exception:
        return []

    workbooks = _cms_final_find_quote_steel_workbooks(job_dir)

    for wb_path in workbooks:
        try:
            wb = openpyxl.load_workbook(wb_path, data_only=True, read_only=True)

            if "QuoteWorksheet" in wb.sheetnames:
                ws = wb["QuoteWorksheet"]
            elif "Quote" in wb.sheetnames:
                ws = wb["Quote"]
            else:
                ws = wb[wb.sheetnames[0]]

            rows_by_role = {}

            max_row = min(ws.max_row, 140)
            for r in range(1, max_row + 1):
                label = ws.cell(r, 1).value
                role = _cms_final_bms_role(label)

                if not role:
                    continue

                qty = _cms_final_qty(ws.cell(r, 3).value, 0)
                thickness = _cms_final_float(ws.cell(r, 4).value)
                width = _cms_final_float(ws.cell(r, 5).value)
                length = _cms_final_float(ws.cell(r, 6).value)

                if qty <= 0 or thickness <= 0 or width <= 0 or length <= 0:
                    continue

                rows_by_role[role] = _cms_final_make_steel_row(
                    role,
                    qty,
                    thickness,
                    width,
                    length,
                    "workbook:" + str(wb_path),
                )

            ordered = []
            for role in _CMS_FINAL_BMS_ORDER:
                if role in rows_by_role:
                    ordered.append(rows_by_role[role])

            if len(ordered) >= 4:
                return ordered

        except Exception:
            continue

    return []


def _cms_final_read_bms_from_bom_match_csv(job_dir):
    from pathlib import Path
    import csv

    if job_dir is None:
        return []

    job_dir = Path(job_dir)

    candidates = [
        job_dir / "XT_Export_BOM_Match_Report.csv",
        job_dir / "documents" / "XT_Export_BOM_Match_Report.csv",
    ]

    csv_path = None
    for p in candidates:
        if p.exists():
            csv_path = p
            break

    if csv_path is None:
        return []

    rows_by_role = {}

    with csv_path.open("r", encoding="utf-8-sig", errors="replace", newline="") as f:
        reader = csv.DictReader(f)

        for row in reader:
            role = _cms_final_bms_role(row.get("QuoteName", ""))
            if not role:
                continue

            thickness = _cms_final_float(row.get("CAD_Thickness"))
            width = _cms_final_float(row.get("CAD_Width"))
            length = _cms_final_float(row.get("CAD_Length"))

            if thickness <= 0:
                thickness = _cms_final_float(row.get("BOM_Thickness"))
            if width <= 0:
                width = _cms_final_float(row.get("BOM_Width"))
            if length <= 0:
                length = _cms_final_float(row.get("BOM_Length"))

            if thickness <= 0 or width <= 0 or length <= 0:
                continue

            qty = _cms_final_qty(row.get("Qty"), 1)

            rows_by_role[role] = _cms_final_make_steel_row(
                role,
                qty,
                thickness,
                width,
                length,
                "job_csv:" + str(csv_path),
            )

    ordered = []
    for role in _CMS_FINAL_BMS_ORDER:
        if role in rows_by_role:
            ordered.append(rows_by_role[role])

    return ordered


def _cms_final_pc_get(row, *names, default=""):
    lookup = {}
    for k, v in (row or {}).items():
        lookup[_cms_final_key(k)] = v

    for name in names:
        k = _cms_final_key(name)
        if k in lookup:
            return lookup[k]

    return default


